{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "moduleResolution": "node",

    /* Strict Checks */
    "strict": true,
    "noImplicitAny": false,

    /* Compatibility Fixes */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    /* Best Practices */
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    /* Build */
    "noEmitOnError": false
  }
}
